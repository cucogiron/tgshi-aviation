"ALQ CUCO FF","ruta":"RIO","piloto":"","hrm_ini":903.0,"hrm_fin":904.8,"hrs":1.8,"tipo":"FF","rev":1170.0},{"date":"2026-03-29","resp":"CUCO","usuario":"CUCO","ruta":"MGPB","piloto":"","hrm_ini":904.8,"hrm_fin":907.2,"hrs":2.4,"tipo":"PERSONAL","rev":0.0},{"date":"2026-03-31","resp":"SENSHI","usuario":"ALQ COCO FF","ruta":"RIO","piloto":"","hrm_ini":907.2,"hrm_fin":909.1,"hrs":1.9,"tipo":"FF","rev":1235.0},{"date":"2026-04-03","resp":"SENSHI","usuario":"ALQ COCO FF","ruta":"RIO","piloto":"","hrm_ini":909.1,"hrm_fin":910.9,"hrs":1.8,"tipo":"FF","rev":1170.0},{"date":"2026-04-04","resp":"COCO","usuario":"ALQ HRS PIVARAL COCO","ruta":"EL ROSARIO","piloto":"","hrm_ini":910.9,"hrm_fin":911.8,"hrs":0.9,"tipo":"STD","rev":675.0},{"date":"2026-04-04","resp":"CUCO","usuario":"CUCO","ruta":"MGPB","piloto":"","hrm_ini":911.8,"hrm_fin":914.1,"hrs":2.3,"tipo":"PERSONAL","rev":0.0},{"date":"2026-04-05","resp":"SENSHI","usuario":"ALQ CUCO FF","ruta":"RIO","piloto":"","hrm_ini":914.1,"hrm_fin":916.0,"hrs":1.9,"tipo":"FF","rev":1235.0}];

const monthly2026 = {"1":{"coco":5.4,"cuco":7.2,"senshi":17.0,"total":29.6},"2":{"coco":0.0,"cuco":0.0,"senshi":4.5,"total":4.5},"3":{"coco":13.1,"cuco":2.4,"senshi":3.7,"total":19.2},"4":{"coco":0.9,"cuco":2.3,"senshi":3.7,"total":6.9}};

const MONTH_NAMES = ['','ENE','FEB','MAR','ABR','MAY','JUN','JUL','AGO','SEP','OCT','NOV','DIC'];
let lastTach = 916.0;
let newEntries = JSON.parse(localStorage.getItem('tgshi_entries') || '[]');
let currentFilter = 'ALL';
let selectedPiloto = 'FERNANDO';
let selectedResp = 'COCO';
let selectedTipo = 'PERSONAL';

// ── INIT ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('tachDisplay').textContent = lastTach.toFixed(1);
  setToday();
  buildDashboard();
  buildFlightList('ALL');
  buildSavedList();
  calcHrs();
  ['f-hrm-ini','f-hrm-fin'].forEach(id => {
    document.getElementById(id).addEventListener('input', calcHrs);
  });
});

function setToday() {
  const d = new Date(); const pad = n => String(n).padStart(2,'0');
  document.getElementById('f-fecha').value = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
}

// ── DASHBOARD ─────────────────────────────────────────────────────────────────
function buildDashboard() {
  const allFlights = [...flights, ...newEntries];

  // 2026 totals
  let coco26=0, cuco26=0, sen26=0;
  allFlights.filter(f=>f.date.startsWith('2026')).forEach(f => {
    if(f.resp==='COCO') coco26+=f.hrs;
    else if(f.resp==='CUCO') cuco26+=f.hrs;
    else sen26+=f.hrs;
  });
  document.getElementById('dash-coco-hrs').textContent = coco26.toFixed(1);
  document.getElementById('dash-cuco-hrs').textContent = cuco26.toFixed(1);
  document.getElementById('dash-senshi-hrs').textContent = sen26.toFixed(1);

  // Month bars
  const maxTotal = Math.max(...Object.values(monthly2026).map(m=>m.total), 1);
  let barsHtml = '';
  for(let m=1; m<=4; m++) {
    const d = monthly2026[m] || {coco:0,cuco:0,senshi:0,total:0};
    const scale = 100/maxTotal;
    barsHtml += `<div class="month-row">
      <div class="month-label">${MONTH_NAMES[m]}</div>
      <div class="bar-track">
        <div class="bar-seg bar-coco" style="width:${d.coco*scale}%"></div>
        <div class="bar-seg bar-cuco" style="width:${d.cuco*scale}%"></div>
        <div class="bar-seg bar-senshi" style="width:${d.senshi*scale}%"></div>
      </div>
      <div class="month-total">${d.total.toFixed(1)}</div>
    </div>`;
  }
  document.getElementById('monthBars').innerHTML = barsHtml;

  // Recent flights (last 5)
  const recent = [...allFlights].reverse().slice(0,5);
  document.getElementById('recentFlights').innerHTML = recent.map(f => flightHTML(f)).join('');

  // Summary
  const total26 = coco26+cuco26+sen26;
  const pct = total26>0 ? t => `${((t/total26)*100).toFixed(0)}%` : ()=>'—';
  document.getElementById('summary2026').innerHTML = `
    <div class="qs-row"><div class="qs-label">Total horas 2026</div><div class="qs-val">${total26.toFixed(1)} hrs</div></div>
    <div class="qs-row"><div class="qs-label">COCO</div><div class="qs-val qs-coco">${coco26.toFixed(1)} hrs (${pct(coco26)})</div></div>
    <div class="qs-row"><div class="qs-label">CUCO</div><div class="qs-val qs-cuco">${cuco26.toFixed(1)} hrs (${pct(cuco26)})</div></div>
    <div class="qs-row"><div class="qs-label">Charter/Shenshi</div><div class="qs-val qs-senshi">${sen26.toFixed(1)} hrs (${pct(sen26)})</div></div>
    <div class="qs-row"><div class="qs-label">Tach actual</div><div class="qs-val">${lastTach.toFixed(1)}</div></div>
    <div class="qs-row"><div class="qs-label">Vuelos registrados</div><div class="qs-val">${allFlights.length}</div></div>
  `;
}

// ── FLIGHT LIST ───────────────────────────────────────────────────────────────
function flightHTML(f) {
  const dotClass = f.resp==='COCO'?'dot-coco':f.resp==='CUCO'?'dot-cuco':'dot-senshi';
  const badge = f.tipo==='STD'?'<span class="badge badge-std">STD</span>':
                f.tipo==='FF'?'<span class="badge badge-ff">FF</span>':
                f.tipo==='MANTE'?'<span class="badge badge-mante">MANTE</span>':
                '<span class="badge badge-personal">Personal</span>';
  const piloto = f.piloto ? `· ${f.piloto}` : '';
  const rev = f.rev>0 ? `· <strong>$${f.rev.toLocaleString()}</strong>` : '';
  return `<div class="flight-item">
    <div class="flight-dot ${dotClass}"></div>
    <div class="flight-main">
      <div class="flight-route">${f.ruta||'—'} ${badge}</div>
      <div class="flight-meta">
        <span>${f.resp}</span><span>${f.usuario}</span>${piloto?`<span>${piloto}</span>`:''}${rev?`<span>${rev}</span>`:''}
      </div>
    </div>
    <div class="flight-right">
      <div class="flight-hrs">${f.hrs.toFixed(1)}<span style="font-size:10px;color:var(--muted)">hr</span></div>
      <div class="flight-date">${f.date.slice(5)}</div>
    </div>
  </div>`;
}

function buildFlightList(filter) {
  const allFlights = [...flights, ...newEntries].reverse();
  let filtered = allFlights;
  if(filter==='COCO') filtered = allFlights.filter(f=>f.resp==='COCO');
  else if(filter==='CUCO') filtered = allFlights.filter(f=>f.resp==='CUCO');
  else if(filter==='SENSHI') filtered = allFlights.filter(f=>f.resp==='SENSHI');
  else if(filter==='2026') filtered = allFlights.filter(f=>f.date.startsWith('2026'));
  else if(filter==='2025') filtered = allFlights.filter(f=>f.date.startsWith('2025'));

  if(filtered.length===0) {
    document.getElementById('flightList').innerHTML = '<div class="empty-state"><div class="big">✈</div>Sin vuelos</div>';
    return;
  }
  document.getElementById('flightList').innerHTML = filtered.slice(0,80).map(flightHTML).join('');
}

function filterFlights(filter, el) {
  currentFilter = filter;
  document.querySelectorAll('#filterRow .filter-pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  buildFlightList(filter);
}

// ── LOG FORM ──────────────────────────────────────────────────────────────────
function switchTab(tab) {
  document.querySelectorAll('.tab').forEach((t,i) => {
    const names = ['dashboard','flights','log'];
    t.classList.toggle('active', names[i]===tab);
  });
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-'+tab).classList.add('active');
}

function setPiloto(val, el) {
  selectedPiloto = val;
  document.querySelectorAll('[onclick^="setPiloto"]').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('f-piloto-otro').style.display = val==='OTRO' ? 'block' : 'none';
}

function setResp(val, el) {
  selectedResp = val;
  document.querySelectorAll('[onclick^="setResp"]').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  updateUsuarioOptions();
}

function setTipo(val, el) {
  selectedTipo = val;
  document.querySelectorAll('.tipo-card').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  const isCharter = val==='STD'||val==='FF';
  document.getElementById('revenueSection').style.display = isCharter ? 'block' : 'none';
  if(isCharter) updateRevHint();
  updateUsuarioOptions();
}

function updateRevHint() {
  const ini = parseFloat(document.getElementById('f-hrm-ini').value)||0;
  const fin = parseFloat(document.getElementById('f-hrm-fin').value)||0;
  const hrs = Math.max(0, fin-ini);
  const rate = selectedTipo==='FF' ? 650 : 750;
  if(hrs>0) document.getElementById('revHint').textContent = `Auto: ${hrs.toFixed(1)}hr × $${rate} = $${(hrs*rate).toFixed(2)}`;
}

function updateUsuarioOptions() {
  const sel = document.getElementById('f-usuario');
  const opts = {
    personal: ['COCO','CUCO'],
    charter_coco: ['ALQ COCO','ALQ COCO FF','ALQ HRS PIVARAL COCO'],
    charter_cuco: ['ALQ CUCO','ALQ CUCO FF','CUCO HRS ADAN'],
    charter_ext:  ['ALQ LICO','ALQ PREMISA','ALQ FER','ALQ LECLAIRE'],
    mante: ['MANTE','SENSHI'],
  };
  let choices = [];
  if(selectedTipo==='PERSONAL') choices = selectedResp==='COCO'?['COCO']:selectedResp==='CUCO'?['CUCO']:['SENSHI'];
  else if(selectedTipo==='MANTE') choices = opts.mante;
  else if(selectedResp==='COCO') choices = [...opts.charter_coco,...opts.charter_ext];
  else if(selectedResp==='CUCO') choices = [...opts.charter_cuco,...opts.charter_ext];
  else choices = [...opts.charter_coco,...opts.charter_cuco,...opts.charter_ext];

  sel.innerHTML = choices.map(v=>`<option value="${v}">${v}</option>`).join('');
}

function calcHrs() {
  const ini = parseFloat(document.getElementById('f-hrm-ini').value);
  const fin = parseFloat(document.getElementById('f-hrm-fin').value);
  const div = document.getElementById('hrsCalc');
  if(!isNaN(ini) && !isNaN(fin) && fin>ini) {
    const hrs = (fin-ini).toFixed(1);
    const billed = parseFloat(hrs)<1.0 ? '1.0 (roundup)' : hrs;
    document.getElementById('hrsResult').textContent = `${hrs}hrs voladas · facturadas: ${billed}`;
    div.style.display = 'block';
    updateRevHint();
  } else {
    div.style.display = 'none';
  }
}

function saveEntry() {
  const fecha = document.getElementById('f-fecha').value;
  const piloto = selectedPiloto==='OTRO' ? document.getElementById('f-piloto-otro').value : selectedPiloto;
  const resp = selectedResp;
  const usuario = document.getElementById('f-usuario').value;
  const ruta = document.getElementById('f-ruta').value.toUpperCase();
  const hrm_ini = parseFloat(document.getElementById('f-hrm-ini').value);
  const hrm_fin = parseFloat(document.getElementById('f-hrm-fin').value);
  const comb = parseFloat(document.getElementById('f-comb').value)||0;
  const espera = parseFloat(document.getElementById('f-espera').value)||0;
  const notes = document.getElementById('f-notes').value;

  if(!fecha||!ruta||isNaN(hrm_ini)||isNaN(hrm_fin)||hrm_fin<=hrm_ini) {
    alert('Por favor completa: Fecha, Ruta, HRM Inicio y HRM Fin (fin > inicio)');
    return;
  }

  const hrs = parseFloat((hrm_fin-hrm_ini).toFixed(1));
  const rate = selectedTipo==='FF'?650:selectedTipo==='STD'?750:0;
  const rev = document.getElementById('f-rev').value ?
    parseFloat(document.getElementById('f-rev').value) :
    (rate>0 ? parseFloat((hrs*rate).toFixed(2)) : 0);

  // Period number for S column
  const d = new Date(fecha);
  const periodo = d.getFullYear()*12 + (d.getMonth()+1);

  const entry = {fecha,piloto,resp,usuario,ruta,hrm_ini,hrm_fin,hrs,comb,espera,tipo:selectedTipo,rev,notes,periodo,
    date:fecha  // for display
  };

  newEntries.unshift(entry);
  localStorage.setItem('tgshi_entries', JSON.stringify(newEntries));

  // Update tach
  lastTach = Math.max(lastTach, hrm_fin);
  document.getElementById('tachDisplay').textContent = lastTach.toFixed(1);

  // Build CSV row for pasting into Excel
  // Columns: # | FECHA | DÍA | PILOTO | RESPONSABLE | USUARIO | RUTA | HRM INI | HRM FIN | HRS VUELO | GAL | COSTO COMB | QTZ/GAL | ESPERA HRS | COSTO ESPERA | COSTO PILOTO | TIPO | INGRESOS $ | PERÍODO
  const days = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
  const dia = days[new Date(fecha+'T12:00:00').getDay()];
  const row = [
    '',fecha,dia,piloto,resp,usuario,ruta,
    hrm_ini,hrm_fin,hrs,
    comb||'','','',
    espera||'','','',
    selectedTipo,rev||'',periodo
  ].join('\t');

  document.getElementById('csvPreview').textContent = row;
  document.getElementById('csvCard').style.display = 'block';

  const sb = document.getElementById('successBar');
  sb.style.display = 'flex';
  setTimeout(()=>sb.style.display='none', 4000);

  buildSavedList();
  buildDashboard();

  // Reset form (keep date and hrm_ini as last tach)
  document.getElementById('f-hrm-ini').value = hrm_fin;
  document.getElementById('f-hrm-fin').value = '';
  document.getElementById('f-ruta').value = '';
  document.getElementById('f-comb').value = '';
  document.getElementById('f-espera').value = '0';
  document.getElementById('f-rev').value = '';
  document.getElementById('f-notes').value = '';
  document.getElementById('hrsCalc').style.display = 'none';
}

function copyCSV() {
  const text = document.getElementById('csvPreview').textContent;
  navigator.clipboard.writeText(text).then(()=>{
    const btn = event.target;
    const orig = btn.textContent;
    btn.textContent = '✓ Copiado';
    setTimeout(()=>btn.textContent=orig, 2000);
  }).catch(()=>alert('Selecciona el texto manualmente y copia'));
}

function buildSavedList() {
  if(newEntries.length===0) { document.getElementById('savedList').innerHTML=''; return; }
  document.getElementById('savedList').innerHTML = `
    <div style="font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:8px">
      Registrados esta sesión (${newEntries.length})
      <button onclick="clearEntries()" style="float:right;font-size:10px;color:var(--red);background:none;border:none;cursor:pointer">Limpiar</button>
    </div>
    <div class="card">${newEntries.map(e=>flightHTML({...e,date:e.fecha,resp:e.resp})).join('')}</div>`;
}

function clearEntries() {
  if(!confirm('¿Borrar todos los registros de esta sesión?')) return;
  newEntries = [];
  localStorage.removeItem('tgshi_entries');
  buildSavedList();
  document.getElementById('csvCard').style.display='none';
}
</script>

